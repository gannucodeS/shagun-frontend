# ─── SHAGUN WEDDING PLANNERS — ENVIRONMENT VARIABLES ───
# Copy this file to .env and fill in your actual values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/shagun_db
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shagun_db

# JWT Secret (use a long random string in production)
JWT_SECRET=shagun_royal_wedding_secret_2024_ajmer_rajasthan
JWT_EXPIRE=7d

# Email (Nodemailer - optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Razorpay (optional - for payment integration)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Admin credentials (for first-time setup)
ADMIN_EMAIL=gannu@shagunadminnweddings.in
ADMIN_PASSWORD=Admin@Shagun2024

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
